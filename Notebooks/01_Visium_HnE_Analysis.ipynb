      "metadata": {
        "id": "640kQg94xsjf"
      }
    },
    {
      "cell_type": "code",
      "execution_count": 1,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "nVnS3aWWv2t9",
        "outputId": "9548320e-3d02-465a-cfe7-c8e2aed8cecb"
      },
      "outputs": [
