    {
      "cell_type": "markdown",
      "source": [
        "### **5. Cluster Spots by Image Features**"
      ],
      "metadata": {
        "id": "otZHUSNg07rY"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def cluster_features(features: pd.DataFrame, like=None) -> pd.Series:\n",
        "    \"\"\"Leiden clustering of image features.\"\"\"\n",
        "    if like is not None:\n",
        "        features = features.filter(like=like)\n",
        "    tmp_adata = ad.AnnData(features)\n",
        "    sc.pp.scale(tmp_adata)\n",
        "    sc.pp.pca(tmp_adata, n_comps=min(10, features.shape[1] - 1))\n",
        "    sc.pp.neighbors(tmp_adata)\n",
        "    sc.tl.leiden(tmp_adata, key_added='leiden_features')\n",
        "    return tmp_adata.obs['leiden_features']\n",
        "\n",
        "adata.obs['image_cluster'] = cluster_features(adata.obsm['features'])\n",
        "\n",
        "print(f\"Image-based clusters: {adata.obs['image_cluster'].nunique()}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "EJY6b0WG1C2X",
        "outputId": "61fd90b3-081a-481a-9a69-c4f9d9d311c2"
      },
      "execution_count": 8,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Image-based clusters: 19\n"
          ]
        }
      ]
    },
